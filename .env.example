# Supabase (Project Settings -> API Keys)
# Ojo: en proyectos nuevos de Supabase, la pantalla ya no se llama "anon key" /
# "service_role key" sino "Publishable key" (sb_publishable_...) y "Secret keys"
# (sb_secret_...). Se usan exactamente igual, solo copia cada valor aqui:
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Los dos emails autorizados a usar la app (separados por coma)
ALLOWED_EMAILS=tu-email@example.com,pareja@example.com

# PlantNet (https://my.plantnet.org/)
PLANTNET_API_KEY=

# Perenual (https://perenual.com/docs/api)
PERENUAL_API_KEY=

# Plant.id (https://web.plant.id/) - identificacion de enfermedades/plagas.
# Opcional: el free tier solo trae 100 creditos. Si la dejas vacia, o si se
# agotan los creditos, la app usa automaticamente Gemini (vision) como
# diagnostico de respaldo.
PLANTID_API_KEY=

# Gemini (https://aistudio.google.com/app/apikey) - free tier, sin facturacion asociada
GEMINI_API_KEY=

# Opcional: si Google retira/renombra el modelo por defecto (gemini-2.5-flash)
# y la app da un error "model not found", puedes forzar otro aqui sin tocar
# codigo. Lista de modelos disponibles con tu key: https://ai.google.dev/gemini-api/docs/models
GEMINI_MODEL=

# Notificaciones push (genera el par con: npx web-push generate-vapid-keys)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:tu-email@example.com

# Secreto para proteger /api/cron/notify (invéntate una cadena larga aleatoria)
CRON_SECRET=
