# Supabase (Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Los dos emails autorizados a usar la app (separados por coma)
ALLOWED_EMAILS=tu-email@example.com,pareja@example.com

# PlantNet (https://my.plantnet.org/)
PLANTNET_API_KEY=

# Perenual (https://perenual.com/docs/api)
PERENUAL_API_KEY=

# Plant.id (https://web.plant.id/) - identificacion de enfermedades/plagas
PLANTID_API_KEY=

# Gemini (https://aistudio.google.com/app/apikey) - free tier, sin facturacion asociada
GEMINI_API_KEY=

# Notificaciones push (genera el par con: npx web-push generate-vapid-keys)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:tu-email@example.com

# Secreto para proteger /api/cron/notify (invéntate una cadena larga aleatoria)
CRON_SECRET=
